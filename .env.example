# Optional LLM enrichment.
#
# SOTA Finder works without API keys by using rule-based extraction only.
# Set one of these variables in your shell if you want AI-assisted extraction.

# Gemini is the default provider when both keys are present.
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic is used when Gemini is not configured or Gemini fails.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
